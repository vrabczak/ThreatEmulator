# Optional: enables the Google satellite choice in the Map panel.
# Enable the Google Maps JavaScript API and restrict this browser key by HTTP referrer.
VITE_GOOGLE_MAPS_API_KEY=

# Optional: enables the Mapy.com outdoor and aerial choices in the Map panel.
# Restrict this browser-visible key by HTTP referrer and to the Map Tiles service.
VITE_MAPY_API_KEY=
